# Solution using One-Pass HashMap. Time: O(n) Space: O(n)
# ------------------------------------------------------------

def twoSum(self, nums: List[int], target: int) -> List[int]:

    HashMap = {} # Value : Index
    for i, n in enumerate(nums):
        diff = target - n
        if diff in HashMap:
            return [HashMap[diff], i]
        HashMap[n] = i
